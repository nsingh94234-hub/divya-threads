  setTimeout(() => {
    const el = document.getElementById(id);
    if(el) el.scrollIntoView({behavior:'smooth'});
  }, 100);
}
 
// ─── RENDER PRODUCTS ─────────────────────────────────────────────────────────
function renderProductGrid() {
  const grid = document.getElementById('products-grid');
  grid.innerHTML = products.map(p => `
    <div class="product-card" onclick="openProduct(${p.id})">
      <div class="product-img" style="background:${p.bgGrad}">
        <div class="product-symbol-main">${p.symbol}</div>
        <div class="product-label-overlay">${p.collection}</div>
        ${p.badge ? `<div class="product-badge">${p.badge}</div>` : ''}
        <button class="product-wishlist" onclick="event.stopPropagation();showToast('Added to wishlist ♥')">♡</button>
      </div>
      <div class="product-info">
        <div class="product-collection">${p.collection}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc-short">${p.desc.substring(0,80)}...</div>
        <div class="product-footer">
          <div class="product-price">
            ${p.oldPrice ? `<span class="old">₹${p.oldPrice}</span>` : ''}
            ₹${p.price}
          </div>
          <button class="add-cart-btn" onclick="event.stopPropagation();quickAddToCart(${p.id})">Add to Cart</button>
        </div>
      </div>
    </div>
  `).join('');
}
 
// ─── PRODUCT DETAIL ───────────────────────────────────────────────────────────
function openProduct(id) {
  currentProduct = products.find(p => p.id === id);
  currentSize = 'L';
  currentQty = 1;
  document.getElementById('detail-name').textContent = currentProduct.name;
  document.getElementById('detail-collection').textContent = currentProduct.collection;
  document.getElementById('detail-price').textContent = '₹'+currentProduct.price;
  document.getElementById('detail-old').textContent = currentProduct.oldPrice ? '₹'+currentProduct.oldPrice : '';
  document.getElementById('detail-symbol').textContent = currentProduct.symbol;
  document.getElementById('detail-img').style.background = currentProduct.bgGrad;
  document.getElementById('detail-desc').textContent = currentProduct.desc;
  document.getElementById('qtyDisplay').textContent = '1';
  document.querySelectorAll('.size-btn').forEach(b => {
    b.classList.toggle('active', b.textContent === 'L');
  });
  showPage('product');
}
 
function selectSize(btn, size) {
  currentSize = size;
  document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}
 
function changeQty(delta) {
  currentQty = Math.max(1, currentQty + delta);
  document.getElementById('qtyDisplay').textContent = currentQty;
}
 
function addCurrentToCart() {
  if(!currentProduct) return;
  addToCart(currentProduct, currentSize, currentQty);
  showToast(`${currentProduct.name} (${currentSize}) added to cart!`);
}
 
function quickAddToCart(id) {
  const p = products.find(x => x.id === id);
  addToCart(p, 'M', 1);
  showToast(`${p.name} added to cart!`);
}
 
function addToCart(product, size, qty) {
  const existing = cart.find(i => i.id === product.id && i.size === size);
  if(existing) { existing.qty += qty; }
  else { cart.push({...product, size, qty}); }
  updateCartCount();
}
 
function updateCartCount() {
  const total = cart.reduce((s,i) => s+i.qty, 0);
  document.getElementById('cartCount').textContent = total;
}
 
// ─── CART ─────────────────────────────────────────────────────────────────────
function renderCart() {
  const el = document.getElementById('cartContent');
  const countEl = document.getElementById('cartItemCountText');
  if(cart.length === 0) {
    el.innerHTML = `<div class="cart-empty">
      <div class="cart-empty-icon">🛒</div>
      <div class="cart-empty-text">Your cart is empty, dear devotee</div>
      <button class="btn-primary" onclick="showPage('home');document.getElementById('featuredProducts').scrollIntoView({behavior:'smooth'})">Browse Collections</button>
    </div>`;
    countEl.textContent = '';
    return;
  }
  const totalItems = cart.reduce((s,i)=>s+i.qty,0);
  const subtotal = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const shipping = subtotal >= 999 ? 0 : 99;
  const total = subtotal + shipping;
  countEl.textContent = totalItems + ' item' + (totalItems>1?'s':'');
  el.innerHTML = cart.map((item,idx) => `
    <div class="cart-item">
      <div class="cart-item-img" style="background:${item.bgGrad}">${item.symbol}</div>
      <div>
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-meta">${item.collection} · Size: ${item.size}</div>
        <div class="cart-qty-wrap">
          <button class="cqty-btn" onclick="cartQty(${idx},-1)">−</button>
          <span class="cqty-num">${item.qty}</span>
          <button class="cqty-btn" onclick="cartQty(${idx},1)">+</button>
        </div>
        <span class="cart-remove" onclick="removeFromCart(${idx})">Remove</span>
      </div>
      <div class="cart-item-price">₹${(item.price*item.qty).toLocaleString('en-IN')}</div>
    </div>
  `).join('') + `
    <div class="cart-summary">
      <div class="cart-summary-row"><span>Subtotal (${totalItems} items)</span><span>₹${subtotal.toLocaleString('en-IN')}</span></div>
      <div class="cart-summary-row"><span>Shipping</span><span>${shipping === 0 ? '🎉 FREE' : '₹'+shipping}</span></div>
      ${shipping > 0 ? '<div style="font-size:0.78rem;color:#7a5a40;text-align:right;margin-top:-8px;margin-bottom:12px;">Add ₹'+(999-subtotal)+' more for free shipping</div>' : ''}
      <div class="cart-summary-total"><span>Total</span><span>₹${total.toLocaleString('en-IN')}</span></div>
      <button class="checkout-wa-btn" onclick="openCheckoutModal()">
        💬 Confirm Order on WhatsApp →
      </button>
      <p style="text-align:center;font-size:0.78rem;color:#7a7060;margin-top:12px;">🔒 Payment via UPI after WhatsApp confirmation</p>
    </div>
  `;
}
 
function cartQty(idx, delta) {
  cart[idx].qty = Math.max(1, cart[idx].qty + delta);
  updateCartCount();
  renderCart();
}
 
function removeFromCart(idx) {
  cart.splice(idx, 1);
  updateCartCount();
  renderCart();
}
 
// ─── WHATSAPP ORDER ───────────────────────────────────────────────────────────
function orderViaWhatsApp() {
  if(!currentProduct) return;
  // Single product quick order
  const tmpCart = [{...currentProduct, size: currentSize, qty: currentQty}];
  openCheckoutModal(tmpCart);
}
 
let orderCart = null;
function openCheckoutModal(overrideCart) {
  orderCart = overrideCart || null;
  document.getElementById('checkoutModal').classList.remove('hidden');
  document.getElementById('custName').value = '';
  document.getElementById('custPhone').value = '';
  document.getElementById('custAddress').value = '';
}
 
function closeModal() {
  document.getElementById('checkoutModal').classList.add('hidden');
}
 
function sendToWhatsApp() {
  const name = document.getElementById('custName').value.trim();
  const phone = document.getElementById('custPhone').value.trim();
  const address = document.getElementById('custAddress').value.trim();
  if(!name || !phone || !address) {
    showToast('⚠️ Please fill all fields!');
    return;
  }
  const items = orderCart || cart;
  if(items.length === 0) { showToast('Cart is empty!'); return; }
  const subtotal = items.reduce((s,i) => s + i.price*i.qty, 0);
  const shipping = subtotal >= 999 ? 0 : 99;
  const total = subtotal + shipping;
  const itemLines = items.map(i => `  • ${i.name} (${i.collection})\n    Size: ${i.size} | Qty: ${i.qty} | ₹${(i.price*i.qty).toLocaleString('en-IN')}`).join('\n');
  const msg = `🙏 *Jai Shree Ram! New Order from DivyaThreads* 🙏\n\n` +
    `━━━━━━━━━━━━━━━━━━━\n` +
    `👤 *Customer Details*\n` +
    `━━━━━━━━━━━━━━━━━━━\n` +
    `Name: ${name}\n` +
    `Phone: ${phone}\n` +
    `Address: ${address}\n\n` +
    `━━━━━━━━━━━━━━━━━━━\n` +
    `🛍️ *Order Items*\n` +
    `━━━━━━━━━━━━━━━━━━━\n` +
    `${itemLines}\n\n` +
    `━━━━━━━━━━━━━━━━━━━\n` +
    `💰 *Order Summary*\n` +
    `━━━━━━━━━━━━━━━━━━━\n` +
    `Subtotal: ₹${subtotal.toLocaleString('en-IN')}\n` +
    `Shipping: ${shipping === 0 ? 'FREE 🎉' : '₹'+shipping}\n` +
    `*Total: ₹${total.toLocaleString('en-IN')}*\n\n` +
    `Please share UPI payment details. I'm ready to pay! 🙏\n\n` +
    `_|| Har Har Mahadev ||_`;
  const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;
  window.open(url, '_blank');
  closeModal();
  if(!orderCart) {
    cart = [];
    updateCartCount();
  }
  showToast('Redirecting to WhatsApp! 🙏');
}
 
// ─── MOBILE MENU ──────────────────────────────────────────────────────────────
function toggleMenu() { document.getElementById('navLinks').classList.toggle('open'); }
function closeMenu() { document.getElementById('navLinks').classList.remove('open'); }
 
// ─── TOAST ────────────────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
 
// ─── INIT ─────────────────────────────────────────────────────────────────────
renderProductGrid();
</script>
</body>
</html>
